# Bu dosya GIT'E COMMIT EDILECEK ornek dosyadir.
# Kopyalayip .env adiyla kaydet ve gercek degerlerle doldur.

# Veritabani
# Lokal gelistirme icin SQLite:
DATABASE_URL=sqlite:///./saha_satis.db
# Neon Postgres icin (rotate ettikten sonra):
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# TomTom Routing API anahtari
# https://developer.tomtom.com/user/me/apps adresinden yeni key olustur
TOMTOM_API_KEY=

# JWT imzalama anahtari (en az 32 karakter random string)
# Uretmek icin: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# OSRM public routing servisi (Faz 1'de kullanilacak)
OSRM_BASE_URL=https://router.project-osrm.org
